# Don't commit bot directories (they're large and often downloaded per-user)
bots/*/

# Keep the bots directory itself
!bots/.gitkeep

# Cached past bot versions (extracted from git history)
bot_versions/

# Generated per-match compose override
docker-compose.override.yml

# Per-match isolated run directories (created at runtime)
runs/

# Runtime artifacts
logs/*/
replays/*.SC2Replay
results.json

# Keep structure files
!logs/.gitkeep
!replays/.gitkeep
!maps/.gitkeep
